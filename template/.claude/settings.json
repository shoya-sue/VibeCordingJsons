{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read(**/*)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(*.json)",
      "Write(*.yml)",
      "Write(*.yaml)",
      "Write(*.toml)",
      "Write(*.md)",
      "Write(${HOME}/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian/**)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/**)",
      "Edit(scripts/**)",
      "Edit(*.json)",
      "Edit(*.yml)",
      "Edit(*.yaml)",
      "Edit(*.toml)",
      "Edit(*.md)",
      "Edit(Makefile)",
      "Edit(Dockerfile)",
      "Bash(mkdir *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker-compose up *)",
      "Bash(docker-compose down *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(terraform plan *)",
      "Bash(terraform show *)",
      "Bash(gh *)",
      "Bash(jq *)",
      "Bash(aws s3 ls *)",
      "Bash(aws s3 cp *)",
      "Bash(gcloud *)",
      "Bash(sentry-cli *)",
      "mcp__*",
      "mcp__obsidian__*",
      "mcp__github__*",
      "mcp__context7__*",
      "mcp__deepwiki__*",
      "mcp__playwright__*",
      "mcp__ide__*",
      "mcp__excalidraw__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Notion__*",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(claude *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Skill(*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(kubectl apply *)",
      "Bash(curl *)",
      "Bash(chmod +x *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Write(**/.git/**)",
      "Write(**/node_modules/**)",
      "Write(**/dist/**)",
      "Write(**/build/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(mkfs *)",
      "Bash(dd if=/dev/zero *)",
      "Bash(terraform apply -auto-approve)",
      "Bash(terraform destroy *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete node *)",
      "Bash(rm -fr *)",
      "Bash(rm --recursive *)",
      "Bash(rm -r *)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git checkout -- *)",
      "Bash(curl * | sh)",
      "Bash(curl * | zsh)",
      "Bash(wget * | sh)",
      "Bash(wget * | zsh)",
      "Bash(curl * > *)",
      "Bash(wget * -O *)",
      "Bash(cat **/.env*)",
      "Bash(cat **/*.key)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/.ssh/**)",
      "Bash(cat **/.aws/**)",
      "Bash(cat **/secrets/**)",
      "Bash(head **/.env*)",
      "Bash(tail **/.env*)",
      "Bash(grep **/.env*)",
      "Bash(chmod u+s *)",
      "Bash(chmod g+s *)",
      "Bash(chmod -R 666 *)",
      "Bash(dd of=/dev/*)"
    ]
  },
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": ".claude/memory",
  "includeGitInstructions": true,
  "modelOverrides": {},
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MCP_TIMEOUT": "30000",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "ECC_HOOK_PROFILE": "standard",
    "ECC_DISABLED_HOOKS": "",
    "ECC_PLUGIN_ROOT": "${HOME}/.claude/plugins/cache/everything-claude-code/everything-claude-code/1.10.0",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "OBSIDIAN_VAULT": "${HOME}/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian"
  },
  "worktree": {
    "sparsePaths": [
      "src/",
      "tests/",
      "docs/",
      "scripts/"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ECC_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"session:start\" \"scripts/hooks/session-start.js\" \"minimal,standard,strict\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/ensure-memory-symlink.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/obsidian-mcp-healthcheck.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/session-title.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2 >/dev/null",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ECC_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:edit:format\" \"scripts/hooks/post-edit-format.js\" \"standard,strict\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__obsidian__*",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/obsidian-mcp-recovery.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ECC_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"stop:session-end\" \"scripts/hooks/session-end.js\" \"minimal,standard,strict\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/obsidian-session-end.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ECC_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"pre:compact\" \"scripts/hooks/pre-compact.js\" \"standard,strict\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/post-compact-snapshot.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/subagent-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${ECC_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"session:end:marker\" \"scripts/hooks/session-end-marker.js\" \"minimal,standard,strict\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "teammateMode": "auto",
  "effortLevel": "xhigh",
  "showThinkingSummaries": true,
  "autoScrollEnabled": true,
  "disableSkillShellExecution": false,
  "sandbox": {
    "failIfUnavailable": false
  },
  "statusLine": {
    "type": "command",
    "command": "${HOME}/.claude/statusline.sh"
  },
  "attribution": {
    "commit": "\n\nGenerated by Claude Code",
    "pr": "\n🤖 Generated by [Claude Code](https://claude.ai/claude-code)"
  }
}
