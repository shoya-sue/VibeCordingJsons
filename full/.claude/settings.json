{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(*.json)",
      "Write(*.yml)",
      "Write(*.yaml)",
      "Write(*.toml)",
      "Write(*.md)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/**)",
      "Edit(scripts/**)",
      "Edit(*.json)",
      "Edit(*.yml)",
      "Edit(*.yaml)",
      "Edit(*.toml)",
      "Edit(*.md)",
      "Edit(Makefile)",
      "Edit(Dockerfile)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker-compose up *)",
      "Bash(docker-compose down *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(terraform plan *)",
      "Bash(terraform show *)",
      "Bash(gh *)",
      "Bash(jq *)",
      "Bash(aws s3 ls *)",
      "Bash(aws s3 cp *)",
      "Bash(gcloud *)",
      "Bash(sentry-cli *)",
      "mcp__*",
      "Skill(*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(kubectl apply *)",
      "Bash(gh issue create *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Write(**/.git/**)",
      "Write(**/node_modules/**)",
      "Write(**/dist/**)",
      "Write(**/build/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(mkfs *)",
      "Bash(dd if=/dev/zero *)",
      "Bash(terraform apply -auto-approve)",
      "Bash(terraform destroy *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete node *)"
    ]
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": ".claude/memory",
  "includeGitInstructions": true,
  "modelOverrides": {},
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MCP_TIMEOUT": "15000",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "BASH_MAX_TIMEOUT_MS": "300000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "worktree": {
    "sparsePaths": [
      "src/",
      "tests/",
      "docs/",
      "scripts/"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[セッション開始] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[プロンプト送信] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行前:Bash] $(jq -r '.tool_input.command // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行前:Write] $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行前:Edit] $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行前:MCP] $(jq -r '.tool_name // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[権限要求] ツール=$(jq -r '.tool_name // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行後:Write] 変更: $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行後:Edit] 変更: $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[実行後:Bash] 完了: $(jq -r '.tool_input.command // empty' 2>/dev/null | head -c 100)\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ツール失敗] ツール=$(jq -r '.tool_name // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[通知] 種別=$(jq -r '.notification_type // .type // \"情報\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[サブエージェント開始] 種別=$(jq -r '.agent_type // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[サブエージェント停止] 種別=$(jq -r '.agent_type // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[応答完了] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "proj=$(basename \"$(git remote get-url origin 2>/dev/null | sed 's/\\.git$//')\" 2>/dev/null || basename \"$(pwd)\") && task=$(cat .claude/current-task 2>/dev/null || git branch --show-current 2>/dev/null || echo '-') && curl -s -X POST -H 'Content-Type: application/json' -d '{\"content\":\"📨 **応答求**\\n📁 '\"$proj\"'\\n🔧 '\"$task\"'\"}' '${DISCORD_WEBHOOK_URL}' >/dev/null 2>&1",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[チームメイト待機] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[タスク完了] $(date '+%H:%M:%S')\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "proj=$(basename \"$(git remote get-url origin 2>/dev/null | sed 's/\\.git$//')\" 2>/dev/null || basename \"$(pwd)\") && task=$(cat .claude/current-task 2>/dev/null || git branch --show-current 2>/dev/null || echo '-') && curl -s -X POST -H 'Content-Type: application/json' -d '{\"content\":\"✅ **完了**\\n📁 '\"$proj\"'\\n🔧 '\"$task\"'\"}' '${DISCORD_WEBHOOK_URL}' >/dev/null 2>&1",
            "timeout": 10
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[設定変更] 元=$(jq -r '.source // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ワークツリー作成] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ワークツリー削除] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[コンテキスト圧縮前] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[コンテキスト圧縮後] $(date '+%H:%M:%S')\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "echo \"[リマインダー] モデル=opusplan(計画:Opus/実行:Sonnet) | サブエージェント積極委任 | gh CLI優先 | TDD | コメント日本語 | 変更は最小限\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[MCP入力要求] サーバー=$(jq -r '.mcp_server_name // \"不明\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[MCP入力結果] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[設定ファイル読込] $(jq -r '.files // empty' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[セッション終了] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "teammateMode": "auto",
  "attribution": {
    "commit": "\n\nGenerated by Claude Code",
    "pr": "\n🤖 Generated by [Claude Code](https://claude.ai/claude-code)"
  }
}
