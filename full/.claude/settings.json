{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(*.json)",
      "Write(*.yml)",
      "Write(*.yaml)",
      "Write(*.toml)",
      "Write(*.md)",
      "Write(Makefile)",
      "Write(Dockerfile)",
      "Edit(**/*)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(terraform plan *)",
      "Bash(terraform show *)",
      "Bash(gh *)",
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(aws s3 ls *)",
      "Bash(aws s3 cp *)",
      "Bash(gcloud *)",
      "Bash(sentry-cli *)",
      "mcp__*",
      "Skill(*)",
      "MCPSearch"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(kubectl apply *)"
    ],
    "deny": [
      "Read(**/.env.production)",
      "Read(**/secrets/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/id_*)",
      "Write(**/.git/**)",
      "Write(**/node_modules/**)",
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf *)",
      "Bash(mkfs *)",
      "Bash(dd if=/dev/zero *)",
      "Bash(chmod -R 777 /)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(terraform apply -auto-approve)",
      "Bash(terraform destroy *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete node *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "language": "japanese",
  "enableAllProjectMcpServers": true,
  "autoMemoryEnabled": true,
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MCP_TIMEOUT": "15000",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "BASH_MAX_TIMEOUT_MS": "300000",
    "ENABLE_TOOL_SEARCH": "auto",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_AUTO_MEMORY_PATH": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code session started\" with title \"Claude Code\" sound name \"Glass\"' ; echo \"[SessionStart] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[UserPromptSubmit] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PreToolUse:Bash] $(jq -r '.tool_input.command // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PreToolUse:File] $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PreToolUse:MCP] $(jq -r '.tool_name // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TOOL=$(jq -r '.tool_name // \"unknown\"') ; osascript -e \"display notification \\\"Permission required: $TOOL\\\" with title \\\"Claude Code\\\" sound name \\\"Basso\\\"\" ; echo \"[PermissionRequest] tool=$TOOL $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PostToolUse:File] modified: $(jq -r '.tool_input.file_path // empty' 2>/dev/null)\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PostToolUse:Bash] completed: $(jq -r '.tool_input.command // empty' 2>/dev/null | head -c 100)\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TOOL=$(jq -r '.tool_name // \"unknown\"') ; osascript -e \"display notification \\\"Tool failed: $TOOL\\\" with title \\\"Claude Code\\\" sound name \\\"Basso\\\"\" ; echo \"[PostToolUseFailure] tool=$TOOL $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TYPE=$(jq -r '.notification_type // .type // \"info\"') ; osascript -e \"display notification \\\"$TYPE\\\" with title \\\"Claude Code\\\" sound name \\\"Tink\\\"\" ; echo \"[Notification] type=$TYPE $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENT=$(jq -r '.agent_type // \"unknown\"') ; osascript -e \"display notification \\\"Subagent started: $AGENT\\\" with title \\\"Claude Code\\\" sound name \\\"Tink\\\"\" ; echo \"[SubagentStart] agent=$AGENT $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENT=$(jq -r '.agent_type // \"unknown\"') ; osascript -e \"display notification \\\"Subagent finished: $AGENT\\\" with title \\\"Claude Code\\\" sound name \\\"Tink\\\"\" ; echo \"[SubagentStop] agent=$AGENT $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished responding\" with title \"Claude Code\" sound name \"Glass\"' ; echo \"[Stop] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[TeammateIdle] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code\" sound name \"Hero\"' ; echo \"[TaskCompleted] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ConfigChange] $(jq -r '.source // \"unknown\"' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[WorktreeCreate] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[WorktreeRemove] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Context compaction starting\" with title \"Claude Code\" sound name \"Tink\"' ; echo \"[PreCompact] $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[InstructionsLoaded] $(jq -r '.files // empty' 2>/dev/null) $(date '+%H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Session ended\" with title \"Claude Code\" sound name \"Hero\"' ; echo \"[SessionEnd] $(date '+%Y-%m-%d %H:%M:%S')\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git", "docker", "gh", "kubectl"],
    "network": {
      "allowedDomains": ["github.com", "registry.npmjs.org", "pypi.org"]
    }
  },
  "teammateMode": "auto",
  "attribution": {
    "commit": "\n\nGenerated by Claude Code",
    "pr": "\n🤖 Generated by [Claude Code](https://claude.ai/claude-code)"
  }
}
